                      "spec": {
                        "query": "from(bucket: \"homedata_reduced\")\r\n  |\u003e range(start: -1d, stop: now())\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"cachedEnergyData.fromBatEnergy\" or r[\"_measurement\"] == \"cachedEnergyData.toBatEnergy\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e last()\r\n  |\u003e pivot(rowKey:[\"_time\"], columnKey:[\"_measurement\"], valueColumn: \"_value\")\r\n  |\u003e drop(columns: [\"_start\", \"_stop\", \"_field\"])\r\n  |\u003e rename(columns: {\"cachedEnergyData.toBatEnergy\": \"toBatEnergy\", \r\n                      \"cachedEnergyData.fromBatEnergy\": \"fromBatEnergy\"})"
