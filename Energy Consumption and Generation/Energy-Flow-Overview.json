                      "datasource": {
                        "name": "bfe557a6-4d7b-46cc-9430-e641780abf2b"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "import \"interpolate\"\r\nimport \"date\"\r\n\r\ndt = (int(v:v.timeRangeStop) - int(v:v.timeRangeStart)) / 1000000000\r\ntSlot = if dt \u003c 21600 then (if dt \u003c 7200 then (if dt \u003c 1800 then 5s else 1m) else 5m) else 15m\r\nt = {timeRangeStart: v.timeRangeStart, timeRangeStop: v.timeRangeStop, windowPeriod: tSlot}\r\n\r\n// using prefix \"m\" for _measurement here\r\nmGrid = \"shelly.0.shellypro3em#0cb815fd0400#1.EM0.TotalActivePower\"\r\nmFromBat = \"mqtt.0.T2SGF72095.ACDISPLAY\"\r\nmToBat = \"mqtt.0.T2MG2CAA11.ACDISPLAY\"\r\nmSolar = \"mqtt.0.solar.116183777340.0.power\"\r\n\r\nfrom(bucket: \"homedata\")\r\n  |\u003e range(start: date.sub(d: 2m, from: t.timeRangeStart), stop: date.add(d: 1m, to: t.timeRangeStop))\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] ==  mToBat or \r\n                       r[\"_measurement\"] == mSolar or \r\n                       r[\"_measurement\"] ==  mGrid or\r\n                       r[\"_measurement\"] == mFromBat)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e interpolate.linear(every: tSlot) \r\n  |\u003e aggregateWindow(every: tSlot, column: \"_value\", fn:mean)\r\n  |\u003e range(start: t.timeRangeStart, stop: t.timeRangeStop)\r\n  |\u003e pivot(rowKey:[\"_time\"], columnKey:[\"_measurement\"], valueColumn: \"_value\")\r\n  |\u003e drop(columns: [\"_start\", \"_stop\", \"_field\"])\r\n  |\u003e rename(columns: {\"mqtt.0.T2MG2CAA11.ACDISPLAY\": \"toBatPower\", \r\n                      \"mqtt.0.T2SGF72095.ACDISPLAY\": \"fromBatPower\",\r\n                      \"shelly.0.shellypro3em#0cb815fd0400#1.EM0.TotalActivePower\": \"GridPower\",\r\n                      \"mqtt.0.solar.116183777340.0.power\": \"SolarPower\"})\r\n  |\u003e map(fn: (r) =\u003e ({ r with consumedPower: r.GridPower + r.SolarPower + r.fromBatPower - r.toBatPower}))"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "kind": "organize",
                  "spec": {
                    "id": "organize",
                    "options": {
                      "excludeByName": {},
                      "indexByName": {
                        "GridPower": 1,
                        "SolarPower": 2,
                        "_time": 0,
                        "consumedPower": 5,
                        "fromBatPower": 3,
                        "toBatPower": 4
                      },
                      "renameByName": {}
                    }
                  }
                }
              ]
            }
          },
          "description": "x-axis time resolution depending on x-axis dispaly range :\u003cbr\u003e\n5s: range \u003c 30m\u003cbr\u003e\n1m: range \u003c 2h\u003cbr\u003e\n5m: range \u003c 6h\u003cbr\u003e\n15m: else  ",
