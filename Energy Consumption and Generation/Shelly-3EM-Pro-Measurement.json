        "description": "Rebuild of the Smart counter value in the cellar of \"Am Rischbleek 40d\" based on the Shelly 3EM Pro installed nearby.\nCounter Reading  was 647 kWh on 29.12.2024",
        "fieldConfig": {
          "defaults": {
            "color": {
              "fixedColor": "light-blue",
              "mode": "fixed"
            },
            "decimals": 2,
            "mappings": [],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "color": "green",
                  "value": 0
