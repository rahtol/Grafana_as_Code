        "pluginVersion": "12.4.2",
        "targets": [
          {
            "datasource": {
              "type": "influxdb",
              "uid": "bfe557a6-4d7b-46cc-9430-e641780abf2b"
            },
            "query": "last_reading =\r\nfrom(bucket: \"homedata\")\r\n  |\u003e range(start: -90d)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] == \"alias.0.smartcounter.reading\")\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e last()\r\n  |\u003e findRecord(idx:0, fn: (key) =\u003e true)\r\n\r\nt0 = last_reading._time\r\ncounter_offset= last_reading._value\r\n\r\n// using prefix \"m\" for _measurement here\r\nmGrid = \"shelly.0.shellypro3em#0cb815fd0400#1.EM0.TotalActivePower\"\r\n\r\nfrom(bucket: \"homedata\")\r\n  |\u003e range(start: t0)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] ==  mGrid)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e elapsed(columnName: \"dt\", unit: 1ms)\r\n  |\u003e map(fn: (r) =\u003e ({ r with kiloWattHours:  if r._value \u003e 0.0 then r._value * float(v:r.dt) / 3600000000.0 else 0.0 })) \r\n  |\u003e drop(columns: [\"_value\", \"dt\"])\r\n  |\u003e rename(columns: {kiloWattHours: \"_value\"})\r\n  |\u003e sum()\r\n  |\u003e map(fn: (r) =\u003e ({ r with _value: r._value + counter_offset }))\r\n",
            "refId": "A"
          }
        ],
        "title": "Smart Counter",
        "type": "stat"
      },
