            "query": "import \"date\"\r\nimport \"timezone\"\r\noption location = timezone.location(name: \"Europe/Berlin\")\r\n\r\nt0 = date.truncate(t: v.timeRangeStart, unit: 1h)\r\nt1 = v.timeRangeStop\r\n\r\nfrom(bucket: \"homedata_reduced\")\r\n\t|\u003e range(start: t0, stop: t1)\r\n\t|\u003e filter(fn: (r) =\u003e r[\"_measurement\"] =~ /cachedEnergyData\\./)\r\n\t|\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n\t|\u003e aggregateWindow(every: 1h, column: \"_value\", fn:first, timeSrc: \"_start\")\r\n\t|\u003e difference(columns: [\"_value\"])\r\n\t|\u003e timeShift(duration: -30m)\r\n\t|\u003e drop(columns: [\"_start\", \"_stop\", \"_field\"])\r\n\t|\u003e pivot(rowKey: [\"_time\"], columnKey: [\"_measurement\"], valueColumn: \"_value\")\r\n\t|\u003e map (fn: (r) =\u003e ({\r\n\t\t\t\t\t\t\t_time: r._time, \r\n\t\t\t\t\t\t\ttoBatEnergy: -r[\"cachedEnergyData.toBatEnergy\"], \r\n\t\t\t\t\t\t\tfromBatEnergy: r[\"cachedEnergyData.fromBatEnergy\"], \r\n\t\t\t\t\t\t\tGridEnergyPos: r[\"cachedEnergyData.fromGridEnergy\"], \r\n\t\t\t\t\t\t\tGridEnergyNeg: -r[\"cachedEnergyData.toGridEnergy\"], \r\n\t\t\t\t\t\t\tSolarEnergy: r[\"cachedEnergyData.solarEnergy\"],\r\n\t\t\t\t\t\t}))\r\n\t|\u003e map(fn: (r) =\u003e ({r with consumedEnergy: -(r.GridEnergyPos + r.GridEnergyNeg + r.SolarEnergy + r.fromBatEnergy + r.toBatEnergy)}))\r\n\t|\u003e sort(columns: [\"_time\"], desc: false)\r\n\t|\u003e yield(name: \"result\")",
            "refId": "A"
          }
