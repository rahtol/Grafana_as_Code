            "query": "import \"interpolate\"\r\nimport \"date\"\r\nimport \"math\"\r\n\r\n// using prefix \"m\" for _measurement here\r\nmGrid = \"shelly.0.shellypro3em#0cb815fd0400#1.EM0.TotalActivePower\"\r\nmFromBat = \"mqtt.0.T2SGF72095.ACDISPLAY\"\r\nmToBat = \"mqtt.0.T2MG2CAA11.ACDISPLAY\"\r\nmSolar = \"mqtt.0.solar.116183777340.0.power\"\r\n\r\ntDuration = 3m\r\ntWindow = 1s\r\n\r\nfrom(bucket: \"homedata\")\r\n  |\u003e range(start: duration (v: -int(v: tDuration)))\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] ==  mToBat or \r\n                       r[\"_measurement\"] == mSolar or \r\n                       r[\"_measurement\"] ==  mGrid or\r\n                       r[\"_measurement\"] == mFromBat)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e interpolate.linear(every: tWindow) \r\n  |\u003e aggregateWindow(every: tWindow, column: \"_value\", fn:last)\r\n  |\u003e fill(usePrevious: true)\r\n  |\u003e last()\r\n  |\u003e pivot(rowKey:[\"_time\"], columnKey:[\"_measurement\"], valueColumn: \"_value\")\r\n  |\u003e drop(columns: [\"_start\", \"_stop\", \"_field\"])\r\n  |\u003e rename(columns: {\"mqtt.0.T2MG2CAA11.ACDISPLAY\": \"toBatPower\", \r\n                      \"mqtt.0.T2SGF72095.ACDISPLAY\": \"fromBatPower\",\r\n                      \"shelly.0.shellypro3em#0cb815fd0400#1.EM0.TotalActivePower\": \"GridPowerPosNeg\",\r\n                      \"mqtt.0.solar.116183777340.0.power\": \"SolarPower\"})\r\n  |\u003e map(fn: (r) =\u003e ({ r with GridPowerPos: if r.GridPowerPosNeg \u003c 0.0 then 0.0 else math.round(x: r.GridPowerPosNeg), \r\n                              GridPowerNeg: if r.GridPowerPosNeg \u003e 0.0 then 0.0 else math.round(x: -r.GridPowerPosNeg)}))\r\n  |\u003e map(fn: (r) =\u003e ({ r with consumedPower: r.GridPowerPosNeg + r.SolarPower + r.fromBatPower - r.toBatPower}))\r\n ",
