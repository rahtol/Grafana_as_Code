            "kind": "QueryGroup",
            "spec": {
              "queries": [
                {
                  "kind": "PanelQuery",
                  "spec": {
                    "hidden": false,
                    "query": {
                      "datasource": {
                        "name": "bfe557a6-4d7b-46cc-9430-e641780abf2b"
                      },
                      "group": "influxdb",
                      "kind": "DataQuery",
                      "spec": {
                        "query": "from(bucket: \"homedata\")\r\n  |\u003e range(start: v.timeRangeStart, stop: v.timeRangeStop)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_measurement\"] =~ /mqtt\\.0\\.LoRa\\.esp32-.*\\.(no_received_packets|no_misssed_packets)/)\r\n  |\u003e filter(fn: (r) =\u003e r[\"_field\"] == \"value\")\r\n  |\u003e difference()\r\n  |\u003e aggregateWindow(every: 15m, fn: sum, createEmpty: true)\r\n  |\u003e fill(value: 0.0)\r\n  |\u003e pivot(rowKey:[\"_time\"], columnKey:[\"_measurement\"], valueColumn: \"_value\")\r\n  |\u003e drop(columns: [\"_start\", \"_stop\", \"_field\"])\r\n  |\u003e rename(columns: {\"mqtt.0.LoRa.esp32-E37630.no_misssed_packets\": \"no_missed_packets\", \r\n                      \"mqtt.0.LoRa.esp32-E37630.no_received_packets\": \"no_received_packets\"})\r\n  |\u003e map(fn: (r) =\u003e ({ r with rate_lost_packets: r.no_missed_packets / (r.no_missed_packets + r.no_received_packets) }))\r\n  |\u003e yield(name: \"rate_lost_packtes\")"
                      },
                      "version": "v0"
                    },
                    "refId": "A"
                  }
                }
              ],
              "queryOptions": {},
              "transformations": [
                {
                  "kind": "organize",
                  "spec": {
                    "id": "organize",
                    "options": {
                      "excludeByName": {
                        "no_missed_packets": false,
                        "no_received_packets": false,
                        "rate_received": false
                      },
                      "includeByName": {},
                      "indexByName": {},
                      "renameByName": {
                        "_time": "Time"
                      }
                    }
                  }
                }
              ]
            }
          },
